---
const faqItems = [
  {
    question: "How do I get started with Hurrian Network services?",
    answer: "Getting started is easy. Simply contact our team through the form on our website, and we'll schedule a consultation to discuss your needs and how we can help."
  },
  {
    question: "What types of businesses do you work with?",
    answer: "We work with businesses of all sizes, from startups to enterprise organizations. Our solutions are scalable and customizable to meet your specific requirements."
  },
  {
    question: "How can I contact your support team?",
    answer: "You can reach our support team via email at support@hurriannetwork.com or through our contact form. We typically respond within 24 hours."
  },
  {
    question: "What regions do you serve?",
    answer: "Hurrian Network provides services globally. Our remote-first approach allows us to support clients anywhere in the world with the same level of dedication."
  },
  {
    question: "Do you offer customized solutions?",
    answer: "Yes, we understand that every business has unique needs. Our team specializes in creating tailored solutions that align with your specific goals and requirements."
  },
  {
    question: "What is your pricing model?",
    answer: "Our pricing is transparent and based on the services you need. We offer flexible plans that can be scaled as your business grows. Contact us for a custom quote."
  }
];

// Randomize and select 3-4 FAQs
const shuffledFAQs = faqItems.sort(() => Math.random() - 0.5);
const selectedFAQs = shuffledFAQs.slice(0, 4);
---

<section class="faq-section">
  <h2>Frequently Asked Questions</h2>
  
  <div class="faq-grid">
    {selectedFAQs.map(item => (
      <details class="faq-item">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </div>
</section>

<style>
  .faq-section {
    padding: 4rem 0;
  }
  
  h2 {
    text-align: center;
    font-size: 2rem;
    margin-bottom: 2rem;
    color: #1a1a2e;
  }
  
  .faq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  
  .faq-item {
    background: #f9f9f9;
    border-radius: 8px;
    padding: 1.5rem;
    border: 1px solid #eee;
  }
  
  .faq-item summary {
    font-weight: 600;
    cursor: pointer;
    list-style: none;
    color: #1a1a2e;
  }
  
  .faq-item summary::-webkit-details-marker {
    display: none;
  }
  
  .faq-item summary::before {
    content: "+";
    display: inline-block;
    margin-right: 0.5rem;
    font-weight: bold;
  }
  
  .faq-item[open] summary::before {
    content: "-";
  }
  
  .faq-item p {
    margin-top: 1rem;
    color: #666;
    line-height: 1.8;
  }
</style>
